{
  "name": "@libraz/libcantus",
  "version": "0.9.3",
  "description": "Pure-TypeScript music-theory and composition primitives (intervals, scales, chords).",
  "type": "module",
  "license": "Apache-2.0",
  "author": "libraz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/libraz/libcantus.git"
  },
  "homepage": "https://github.com/libraz/libcantus#readme",
  "bugs": {
    "url": "https://github.com/libraz/libcantus/issues"
  },
  "keywords": [
    "music-theory",
    "music",
    "chords",
    "scales",
    "intervals",
    "harmony",
    "composition"
  ],
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "yarn@4.17.0",
  "volta": {
    "node": "22.22.3",
    "yarn": "4.17.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core/index.d.ts",
        "default": "./dist/core/index.js"
      },
      "require": {
        "types": "./dist/core/index.d.cts",
        "default": "./dist/core/index.cjs"
      }
    },
    "./theory": {
      "import": {
        "types": "./dist/theory/index.d.ts",
        "default": "./dist/theory/index.js"
      },
      "require": {
        "types": "./dist/theory/index.d.cts",
        "default": "./dist/theory/index.cjs"
      }
    },
    "./analyze": {
      "import": {
        "types": "./dist/analyze/index.d.ts",
        "default": "./dist/analyze/index.js"
      },
      "require": {
        "types": "./dist/analyze/index.d.cts",
        "default": "./dist/analyze/index.cjs"
      }
    },
    "./generate": {
      "import": {
        "types": "./dist/generate/index.d.ts",
        "default": "./dist/generate/index.js"
      },
      "require": {
        "types": "./dist/generate/index.d.cts",
        "default": "./dist/generate/index.cjs"
      }
    },
    "./model": {
      "import": {
        "types": "./dist/model/index.d.ts",
        "default": "./dist/model/index.js"
      },
      "require": {
        "types": "./dist/model/index.d.cts",
        "default": "./dist/model/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench:timeline": "yarn build && node --expose-gc benchmark/timeline-index.mjs",
    "docs": "typedoc",
    "prepare": "[ -d node_modules/typescript ] && tsup || true",
    "prepublishOnly": "yarn build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@libraz/typedoc-theme": "^0.1.1",
    "@vitest/coverage-v8": "4.1.9",
    "tsup": "8.5.1",
    "typedoc": "0.28.20",
    "typedoc-plugin-extras": "4.0.1",
    "typedoc-plugin-mdn-links": "5.1.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
